{
  "name": "ai-agent",
  "displayName": "AI Agent",
  "description": "AI coding assistant supporting LM Studio and Groq",
  "version": "0.0.1",
  "publisher": "anparasan",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },

  "activationEvents": [
    "onCommand:ai-agent.openChat"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-agent.openChat",
        "title": "Open AI Chat"
      }
    ],
    "configuration": {
      "title": "AI Agent",
      "properties": {
        "aiAgent.provider": {
          "type": "string",
          "enum": ["lmstudio", "groq"],
          "enumDescriptions": [
            "Local LM Studio server (default)",
            "Groq cloud API"
          ],
          "default": "groq",
          "description": "AI provider to use"
        },
        "aiAgent.lmStudioUrl": {
          "type": "string",
          "default": "http://localhost:1234/v1",
          "description": "LM Studio server base URL"
        },
        "aiAgent.lmStudioModel": {
          "type": "string",
          "default": "qwen/qwen3-4b-2507",
          "description": "Model ID loaded in LM Studio"
        },
        "aiAgent.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key — get one at https://console.groq.com/keys"
        },
        "aiAgent.groqModel": {
          "type": "string",
          "default": "llama-3.3-70b-versatile",
          "description": "Groq model to use"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "extension:package": "vsce package",
    "extension:install": "code --install-extension ai-agent-0.0.1.vsix",
    "extension:uninstall": "code --uninstall-extension anparasan.ai-agent || true",
    "extension:reinstall": "bun run extension:package && bun run extension:install",
    "extension:clean": "rm -f ai-agent-*.vsix && bun run extension:uninstall",
    "extension:dev": "bun run extension:clean && bun run extension:reinstall",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "extension:publish": "vsce publish",
    "extension:publish:prerelease": "vsce publish --pre-release",
    "extension:publish:patch": "vsce publish --patch",
    "extension:publish:minor": "vsce publish --minor",
    "extension:publish:major": "vsce publish --major"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "oxfmt": "^0.50.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Anparasan3/ai-agent"
  },
  "dependencies": {
    "openai": "^4.0.0"
  }
}
